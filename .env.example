# whoreps-mcp configuration — copy to `.env` and fill in.
#
# The FEDERAL tier (U.S. Senators + House member) and the geocoder need NO keys:
# the Census geocoder and the unitedstates/congress-legislators dataset are both
# free and key-less. Keys below only unlock the state tier and enrichment, and
# the server degrades gracefully without them.

# OpenStates v3 — free key from https://openstates.org/accounts/profile/
# Unlocks the STATE LEGISLATOR tier. Without it, federal + governor still work.
OPENSTATES_API_KEY=

# Congress.gov — optional, free key from https://api.data.gov/signup/
# Only used to enrich get_official_details (committees, full contact).
CONGRESS_GOV_API_KEY=

# Where the SQLite cache lives (geocodes + rosters). Defaults to ./data/whoreps-cache.sqlite
# CACHE_PATH=./data/whoreps-cache.sqlite
